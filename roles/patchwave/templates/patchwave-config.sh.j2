# PatchWave runtime configuration — generated by Ansible.
# Do not edit manually; re-run deploy_patchwave.yml to update.

# Host identity
HOSTNAME="{{ inventory_hostname }}"

# Directories
STATE_DIR="{{ patchwave_state_dir }}"
LOG_DIR="{{ patchwave_log_dir }}"
CONFIG_DIR="{{ patchwave_config_dir }}"
SCRIPT_DIR="{{ patchwave_script_dir }}"

# Notifications
NTFY_TOPIC="{{ patchwave_ntfy_topic }}"
NOTIFY_LEVEL="{{ patchwave_notify_level | default('always') }}"
WEBHOOK_ON_SUCCESS="{{ patchwave_webhook_on_success | default('') }}"
WEBHOOK_ON_FAIL="{{ patchwave_webhook_on_fail | default('') }}"
TLS_INSECURE="{{ patchwave_tls_insecure | default(false) | lower }}"

# Observability
EVENT_LOG="{{ patchwave_event_log }}"

# Patch behavior
SCRIPT_TIMEOUT={{ patchwave_script_timeout }}

# Service management
# SERVICES: stopped top-to-bottom before reboot
# SERVICES_REVERSED: started bottom-to-top after reboot
SERVICES=({{ patchwave_services | join(' ') }})
SERVICES_REVERSED=({{ patchwave_services | reverse | join(' ') }})

# Script paths
PRE_REBOOT_SCRIPT="{{ patchwave_script_dir }}/patchwave-pre-reboot.sh"
