dpkg-query -W -f='${Package}=${Version}\n' | sort > "$PKGLIST_BEFORE"
log "Running apt-get update & {{ patchwave_apt_upgrade_mode | default('upgrade') }}..."

# DEBIAN_FRONTEND=noninteractive: suppresses all interactive prompts (e.g. debconf dialogs)
#   that would otherwise block execution in unattended/headless environments.
# --force-confdef: when a config file is modified by an update, use the package maintainer's
#   recommended default action rather than prompting.
# --force-confold: fallback if no default is defined — keep the locally installed config file.
#   This protects custom configs (e.g. /etc/ssh/sshd_config) from being silently overwritten.

DEBIAN_FRONTEND=noninteractive apt-get update >> "$PATCH_UPDATES_LOG_FILE" 2>&1 \
    && DEBIAN_FRONTEND=noninteractive apt-get {{ patchwave_apt_upgrade_mode | default('upgrade') }} -y \
        -o Dpkg::Options::="--force-confdef" \
        -o Dpkg::Options::="--force-confold" \
        >> "$PATCH_UPDATES_LOG_FILE" 2>&1 \
    || error_exit "APT update failed on $HOSTNAME!"
dpkg-query -W -f='${Package}=${Version}\n' | sort > "$PKGLIST_AFTER"
