#!/bin/bash
#
# patchwave-pre-reboot.sh — Pre-reboot hook
#
# Called by patchwave-patch.sh when a reboot is required.
# Stops defined systemd services in order, runs custom pre-reboot scripts,
# sets a marker file so the post-reboot script knows this was a patch reboot,
# sends a reboot notification, and initiates the reboot.
#

LOG_DIR="{{ patchwave_log_dir }}"
STATE_DIR="{{ patchwave_state_dir }}"
TIMESTAMP_FILE="$STATE_DIR/patch_timestamp"
MARKER_FILE="$STATE_DIR/patchwave_reboot"
NTFY_TOPIC="{{ patchwave_ntfy_topic }}"
HOSTNAME="{{ inventory_hostname }}"
SERVICES=({{ patchwave_services | join(' ') }})
SCRIPT_TIMEOUT={{ patchwave_script_timeout }}
NOTIFY_LEVEL="{{ patchwave_notify_level | default('always') }}"
WEBHOOK_ON_FAIL="{{ patchwave_webhook_on_fail | default('') }}"
EVENT_LOG="{{ patchwave_event_log }}"

mkdir -p "$LOG_DIR"
mkdir -p "$STATE_DIR"

if [ ! -f "$TIMESTAMP_FILE" ]; then
    echo "No timestamp file found. Exiting."
    exit 1
fi

TIMESTAMP="$(cat "$TIMESTAMP_FILE")"
LOG_FILE="${LOG_DIR}/summary_${TIMESTAMP}.log"

# Source shared functions
source {{ patchwave_config_dir }}/bin/functions.sh

log "=== Pre-reboot: stopping services on $HOSTNAME ==="

for SERVICE in "${SERVICES[@]}"; do
    log "Stopping $SERVICE..."
    systemctl stop "$SERVICE" || error_exit "Failed to stop $SERVICE on $HOSTNAME!"
done

log "All systemd services stopped successfully."

{% if patchwave_pre_reboot_scripts | default([]) | length > 0 %}
log "Running custom pre-reboot scripts..."

{% for script in patchwave_pre_reboot_scripts %}
log "Executing custom script: {{ script }} with timeout of $SCRIPT_TIMEOUT seconds"
if [[ ! -x "{{ script }}" ]]; then
    error_exit "Custom pre-reboot script {{ script }} is not executable or not found on $HOSTNAME!"
fi
timeout "$SCRIPT_TIMEOUT" "{{ script }}"
EXIT_CODE=$?
if [ $EXIT_CODE -eq 124 ]; then
    error_exit "Custom pre-reboot script {{ script }} timed out on $HOSTNAME!"
elif [ $EXIT_CODE -ne 0 ]; then
    error_exit "Custom pre-reboot script {{ script }} failed on $HOSTNAME!"
fi
log "Custom script {{ script }} executed successfully."

{% endfor %}
log "All custom pre-reboot scripts executed successfully."
{% else %}
log "No custom pre-reboot scripts configured."
{% endif %}

touch "$MARKER_FILE"

log "Rebooting system now..."

send_notification \
    "Rebooting – $HOSTNAME" \
    "default" \
    "arrows_counterclockwise,package" \
    "Host: $HOSTNAME
Status: Rebooting after patching
Services stopped successfully. System will come back up shortly."

# Brief pause to allow the notification request to complete before network goes down
sleep 3

reboot
